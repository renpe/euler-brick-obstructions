# Copy this file to `.env` and adjust paths to your local environment.
# Loaded automatically by scripts/paper4/_common/pub_db.py via python-dotenv.

# ---------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------
# Connection string in libpq keyword form. The default below points to
# the development database; replace with your own.
EULER_DB=host=192.168.178.63 port=5432 dbname=euler user=euler password=euler

# ---------------------------------------------------------------------
# External binaries
# ---------------------------------------------------------------------
# Override only if the binaries are not on PATH.
# YAFU_BIN=/home/yourname/opt/yafu/yafu
# SAGE_BIN=/home/yourname/miniforge3/envs/sage/bin/sage
# CADO_NFS=/home/yourname/opt/cado-nfs/cado-nfs.py
# CADO_VENV_PY=/home/yourname/opt/cado-nfs/cado-nfs.venv/bin/python
